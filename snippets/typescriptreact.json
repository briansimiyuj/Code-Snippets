    "ContextProvider":{
        "prefix": "ct",
        "body":[
            "import { createContext, useContext } from \"react\"",
            "",
            "interface ${TM_FILENAME_BASE}ProviderProps{",
            "",
            "    children: React.ReactNode",
            "",
            "}",
            "",
            "export const ${TM_FILENAME_BASE} = createContext<${TM_FILENAME_BASE}Props$1 | undefined>(undefined)",
            "",
            "export const ${TM_FILENAME_BASE}Provider:React.FC<${TM_FILENAME_BASE}ProviderProps> = ({ children })=>{",
            "",
            "    const $2",
            "",
            "    const contextValue: ${TM_FILENAME_BASE}Props ={",
            "",
            "        $3",
            "",
            "    }",
            "", 
            "    return(",
            "",
            "        <${TM_FILENAME_BASE}.Provider value={contextValue}>",
            "",
            "            {children}",
            "",
            "        </${TM_FILENAME_BASE}.Provider>",
            "",
            "    )",
            "",
            "}",
            "",
            "export const use${TM_FILENAME_BASE} = () =>{",
            "",
            "     const context = useContext(${TM_FILENAME_BASE})",
            "",
            "     if(!context) throw new Error('use${TM_FILENAME_BASE} must be used within ${TM_FILENAME_BASE}Provider')",
            "",
            "     return context",
            "",
            "}"
        ]
    },

